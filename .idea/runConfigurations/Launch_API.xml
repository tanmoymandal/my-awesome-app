<component name="ProjectRunConfigurationManager">
  <configuration default="false" name="Launch API" type="SpringBootApplicationConfigurationType" factoryName="Spring Boot">
    <module name="api" />
    <option name="SPRING_BOOT_MAIN_CLASS" value="com.example.myawesomeapp.api.ApiApplication" />
    <option name="ALTERNATIVE_JRE_PATH" />
    <option name="SHORTEN_COMMAND_LINE" method="ARGS_FILE" />
    <envs>
      <env name="ENV_FILE" value="$PROJECT_DIR$/api/.env" />
    </envs>
    <option name="PROGRAM_PARAMETERS" value="" />
    <method v="2">
      <option name="Make" enabled="true" />
    </method>
  </configuration>
</component>
